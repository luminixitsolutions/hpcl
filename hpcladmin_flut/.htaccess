# Enable rewrite
RewriteEngine On

# Redirect requests with .php in URL to clean URL (skip ajax_files — POST would become GET and lose data)
RewriteCond %{REQUEST_URI} !/ajax_files/ [NC]
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# Internally map clean URLs to .php files
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]
