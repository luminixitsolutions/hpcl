# Database credentials (never commit the real .env file)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hpcl
DB_USER=your_db_user
DB_PASS=your_db_password

# Optional mysqldump binary path (leave empty to use PATH)
# MYSQLDUMP_BIN=/usr/bin/mysqldump

# Optional: absolute path to this project's Git repo root.
# Leave empty to auto-detect from this script location (../../ from db_backup).
# GIT_REPO_ROOT=/home/USERNAME/public_html/hpcl

# Optional Git remote / branch (defaults shown)
GIT_REMOTE=origin
GIT_BRANCH=main

# Keep only the last N dated backup folders (0 = keep all)
RETENTION_DAYS=14
